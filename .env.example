# VIT Tachyon Fabric — environment template
PORT=8080
ENVIRONMENT=development

# Database
DATABASE_URL=sqlite+aiosqlite:///./tachyon.db

# Redis (optional — for manifest persistence)
REDIS_URL=

# Google Drive (service account JSON key path or base64)
GDRIVE_SERVICE_ACCOUNT_JSON=
GDRIVE_ACCOUNT_1_FOLDER_ID=
GDRIVE_ACCOUNT_2_FOLDER_ID=

# OneDrive (Microsoft Graph OAuth2)
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
ONEDRIVE_TENANT_ID=
ONEDRIVE_ACCOUNT_1_FOLDER_ID=
ONEDRIVE_ACCOUNT_2_FOLDER_ID=

# Dropbox
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_ACCESS_TOKEN=

# VIT Network (parent app DB for storage verification)
VIT_DATABASE_URL=
